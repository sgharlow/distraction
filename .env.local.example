# ═══════════════════════════════════════════════════════════════
# The Distraction Index — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# News APIs
GNEWS_API_KEY=your-gnews-key

# Vercel Cron Authentication
CRON_SECRET=generate-a-random-secret-here

# Site
NEXT_PUBLIC_SITE_URL=https://distractionindex.org

# Google Indexing API (optional — for instant indexing of new content)
# Base64-encoded contents of the Google Cloud service account JSON key file.
# The service account must have the Indexing API enabled, and its email must
# be added as an owner in Google Search Console for distractionindex.org.
# Generate with: cat service-account-key.json | base64 -w0
GOOGLE_INDEXING_KEY=
